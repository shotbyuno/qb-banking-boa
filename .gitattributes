# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Lua source
*.lua text eol=lf

# Web assets
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# SQL
*.sql text eol=lf

# Markdown
*.md text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.zip binary
